# Add these in Streamlit Cloud Dashboard → App Settings → Secrets
# Format: TOML syntax

# Groq API (recommended for cloud — free at https://console.groq.com)
GROQ_API_KEY = "gsk_your_groq_api_key_here"
GROQ_MODEL = "llama-3.1-8b-instant"

# LLM_PROVIDER: "auto" (default), "groq", or "ollama"
LLM_PROVIDER = "auto"

# Ollama (only if you have a public Ollama server)
# OLLAMA_BASE_URL = "http://your-ollama-server:11434"
# OLLAMA_MODEL = "mistral:7b"
